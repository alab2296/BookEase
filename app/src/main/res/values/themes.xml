<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BookEase" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, default is white. -->
        <item name="windowSplashScreenBackground">#0F172A</item>
        <!-- Use windowSplashScreenAnimatedIcon to add a custom icon. -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Set the theme of the Activity that directly follows your splash screen. -->
        <item name="postSplashScreenTheme">@style/Theme.BookEase</item>
    </style>
</resources>